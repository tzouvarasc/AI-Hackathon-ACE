PROVIDER_MODE=hybrid
PUBLIC_BASE_URL=http://localhost:8000

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=wss://your-livekit-host
LIVEKIT_SIP_INBOUND_TRUNK_ID=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
LIVEKIT_SIP_ROOM_PREFIX=thalpo-pstn-
LIVEKIT_SIP_DISPATCH_METADATA=

# Telnyx webhook/call-control mode (for direct phone testing)
TELNYX_API_KEY=
TELNYX_ENABLE_TRANSCRIPTION=true
TELNYX_TRANSCRIPTION_TRACKS=inbound
TELNYX_SPEAK_FALLBACK_VOICE=female

DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=el

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_REQUEST_TIMEOUT_SECONDS=20

# LLM provider: openai | azure
LLM_PROVIDER=openai

# Azure OpenAI (used when LLM_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional Azure server-STT deployment (e.g. gpt-4o-mini-transcribe)
AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT=

# TTS backend: google (recommended for Leda) | cartesia
TTS_BACKEND=google
TTS_OUTPUT_DIR=/tmp/thalpo_audio

# Google Chirp 3 HD - Leda
GOOGLE_TTS_LANGUAGE_CODE=el-GR
GOOGLE_TTS_VOICE_NAME=el-GR-Chirp3-HD-Leda
GOOGLE_TTS_SPEAKING_RATE=0.95
# Optional if running in Docker without mounted key file:
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Optional Cartesia fallback
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-2

# PSTN turn bridge defaults
PSTN_LANGUAGE=el-GR
PSTN_GREETING_TEXT=Γεια σας! Είμαι η Λήδα. Χαίρομαι που σας ακούω. Πώς αισθάνεστε σήμερα;

ANALYSIS_ENGINE_URL=http://analysis-engine:8001
ALERT_ENGINE_URL=http://alert-engine:8002
FAMILY_API_URL=http://family-api:8003
INTERNAL_SERVICE_TOKEN=thalpo-internal-dev

REDIS_URL=redis://redis:6379/0
REDIS_STREAM_TURNS=thalpo.turns
ANALYSIS_ASYNC_ENABLED=true
REQUEST_TIMEOUT_SECONDS=4.0
